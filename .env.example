# Optional bootstrap token. You can also set/replace it from the web panel.
# Cloudflare Dashboard -> Zero Trust -> Networks -> Tunnels -> your tunnel -> Install connector -> Docker
TUNNEL_TOKEN=

# Optional panel security. Open http://localhost:18088 and log in with this value.
PANEL_AUTH_TOKEN=
PANEL_PORT=18088

# Optional: probe the public hostname through the tunnel. Example:
# ORIGIN_PROBE_URL=https://app.example.com/health
ORIGIN_PROBE_URL=
ORIGIN_ACCEPT_STATUS_CODES=200-299

# Tunnel protocol: auto, quic, or http2. You can also change it from the web panel.
TUNNEL_PROTOCOL=auto

# Heartbeat / reconnect policy
HEARTBEAT_INTERVAL_MS=60000
HEARTBEAT_TIMEOUT_MS=10000
RESTART_FAILURE_THRESHOLD=3
RESTART_COOLDOWN_MS=120000

# Advanced cloudflared args, inserted before "run".
# Example: CLOUDFLARED_ARGS=--loglevel info
CLOUDFLARED_ARGS=

# Advanced cloudflared args appended after "tunnel run ...".
CLOUDFLARED_POST_ARGS=

# Alternative local-config mode if you do not use TUNNEL_TOKEN:
# TUNNEL_NAME=my-tunnel
# TUNNEL_CONFIG=/data/config.yml
